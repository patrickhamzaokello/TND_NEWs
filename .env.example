APP_ENV=development
DEBUG=False
DJANGO_SECRET_KEY=replace-with-strong-secret
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
SOCIAL_SECRET=replace-with-social-secret

WEB_GOOGLE_CLIENT_ID=replace-with-web-client-id
IOS_GOOGLE_CLIENT_ID=replace-with-ios-client-id
ANDROID_GOOGLE_CLIENT_ID=replace-with-android-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

EMAIL_HOST_USER=replace-with-email-user
EMAIL_HOST_PASSWORD=replace-with-email-password
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_PLUNK_API_KEY=replace-with-plunk-key

DB_DRIVER=django.db.backends.postgresql
POSTGRES_DB=tnd
POSTGRES_USER=tnd_user
POSTGRES_PASSWORD=replace-with-db-password
PG_HOST=postgres_db
PG_PORT=5432
PG_HOST_PORT=5433
APP_PORT=6200

REDIS_PASSWORD=replace-with-redis-password
REDIS_DATABASE_SERVER_HOST=redis://:replace-with-redis-password@redis:6379/0
REDIS_HOST_PORT=6380

OPENAI_API_KEY=replace-with-openai-key
ENRICHMENT_MODEL=gpt-4o-mini
DIGEST_MODEL=gpt-4o-mini
DIGEST_AUTO_PUBLISH=True

NOTIFICATION_SERVICE_URL=http://notification-service:4000/api/push-notification
DRF_USER_THROTTLE_RATE=1000/hour
DRF_ANON_THROTTLE_RATE=100/hour

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
OTEL_SERVICE_NAME=tndnews-backend
